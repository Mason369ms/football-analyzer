# Football Analyzer 环境变量配置示例
# 复制此文件为 .env 并修改相应的值

# ============================================================
# 服务器配置
# ============================================================
FOOTBALL_HOST=127.0.0.1
FOOTBALL_PORT=8766
FOOTBALL_OPEN_BROWSER=true
FOOTBALL_RELOAD=false

# ============================================================
# 数据库配置
# ============================================================
FOOTBALL_DB_PATH=data/app_football.sqlite3
FOOTBALL_DB_POOL_SIZE=5
FOOTBALL_DB_JOURNAL_MODE=WAL
FOOTBALL_DB_CACHE_SIZE=4000

# ============================================================
# LLM 配置
# ============================================================
FOOTBALL_LLM_PROVIDER=openai
FOOTBALL_LLM_BASE_URL=https://api.openai.com/v1
FOOTBALL_LLM_MODEL=gpt-4
FOOTBALL_LLM_API_KEY=your-api-key-here
FOOTBALL_LLM_MAX_TOKENS=8000
FOOTBALL_LLM_TEMPERATURE=0.3
FOOTBALL_LLM_TIMEOUT=120

# ============================================================
# 认证配置
# ============================================================
FOOTBALL_ADMIN_USER=admin
FOOTBALL_ADMIN_PASSWORD=your-secure-password
FOOTBALL_AUTH_SESSION_TTL_DAYS=7
FOOTBALL_AUTH_PASSWORD_ITERATIONS=260000

# ============================================================
# HTTP 客户端配置
# ============================================================
FOOTBALL_SSL_VERIFY=true
FOOTBALL_RETRY_COUNT=3
FOOTBALL_USE_PROXY=false
FOOTBALL_HTTP_TIMEOUT=15

# ============================================================
# 缓存配置
# ============================================================
FOOTBALL_CACHE_ENABLED=true
FOOTBALL_CACHE_ANALYSIS_TTL=300
FOOTBALL_CACHE_MATCH_TTL=600
FOOTBALL_CACHE_ODDS_TTL=180
FOOTBALL_CACHE_MAX_SIZE=1000

# ============================================================
# 日志配置
# ============================================================
FOOTBALL_LOG_LEVEL=INFO
FOOTBALL_LOG_JSON_FORMAT=false
FOOTBALL_LOG_FILE=

# ============================================================
# 备份配置
# ============================================================
FOOTBALL_BACKUP_ENABLED=true
FOOTBALL_BACKUP_INTERVAL_HOURS=24
FOOTBALL_BACKUP_BACKUP_TIME=03:00
FOOTBALL_BACKUP_MAX_BACKUPS=30
FOOTBALL_BACKUP_COMPRESS=true

# ============================================================
# 监控配置
# ============================================================
FOOTBALL_MONITOR_ENABLED=true
FOOTBALL_MONITOR_METRICS_PORT=9090
FOOTBALL_MONITOR_SENTRY_DSN=

# ============================================================
# 调试配置
# ============================================================
FOOTBALL_DEBUG=false
FOOTBALL_DATA_DIR=data
FOOTBALL_REPORTS_DIR=reports
